diff --git a/src/vite-env.d.ts b/src/vite-env.d.ts
index 70c0e5f..3b26346 100644
--- a/src/vite-env.d.ts
+++ b/src/vite-env.d.ts
@@ -2,3 +2,6 @@
 
 /** App version injected by Vite's `define` from package.json. */
 declare const __APP_VERSION__: string
+
+/** ISO timestamp captured at Vite config-load time (build moment). */
+declare const __APP_BUILD_TIME__: string
diff --git a/vite.config.ts b/vite.config.ts
index 7c0d58f..5ee7267 100644
--- a/vite.config.ts
+++ b/vite.config.ts
@@ -20,6 +20,10 @@ export default defineConfig(async () => ({
 
   define: {
     __APP_VERSION__: JSON.stringify(pkgJson.version),
+    // Capture the build moment so the About panel can show when
+    // this bundle was produced. Evaluated once at config-load time
+    // (i.e. when `vite build` / `vite dev` starts).
+    __APP_BUILD_TIME__: JSON.stringify(new Date().toISOString()),
   },
 
   // Vite options tailored for Tauri development and only applied in `tauri dev` or `tauri build`
