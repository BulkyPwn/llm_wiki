+const SPECULATIVE_SCAN_KEY = "speculativeScanEnabled"
+
+export async function saveSpeculativeScanEnabled(enabled: boolean): Promise<void> {
+  const store = await getStore()
+  await store.set(SPECULATIVE_SCAN_KEY, enabled)
