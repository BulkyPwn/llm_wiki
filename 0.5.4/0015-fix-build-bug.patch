From 7ab3b5c8aebedfe16feebadcb1a75c20dabf5022 Mon Sep 17 00:00:00 2001
From: BulkyPwn <BulkyPwn@gmail.com>
Date: Thu, 2 Jul 2026 21:11:46 +0800
Subject: [PATCH 15/23] fix build bug

---
 src-tauri/Cargo.lock      | 5 +++--
 src-tauri/Cargo.toml      | 4 ++++
 src-tauri/tauri.conf.json | 2 +-
 src/App.tsx               | 6 ++++++
 4 files changed, 14 insertions(+), 3 deletions(-)

diff --git a/src-tauri/Cargo.lock b/src-tauri/Cargo.lock
index 5ae990b..63dd861 100644
--- a/src-tauri/Cargo.lock
+++ b/src-tauri/Cargo.lock
@@ -2358,9 +2358,9 @@ checksum = "877a4ace8713b0bcf2a4e7eec82529c029f1d0619886d18145fea96c3ffe5c0f"
 
 [[package]]
 name = "erased-serde"
-version = "0.4.10"
+version = "0.4.9"
 source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "d2add8a07dd6a8d93ff627029c51de145e12686fbc36ecb298ac22e74cf02dec"
+checksum = "89e8918065695684b2b0702da20382d5ae6065cf3327bc2d6436bd49a71ce9f3"
 dependencies = [
  "serde",
  "serde_core",
@@ -4469,6 +4469,7 @@ dependencies = [
  "calamine",
  "chrono",
  "docx-rs",
+ "erased-serde",
  "futures",
  "image",
  "lancedb",
diff --git a/src-tauri/Cargo.toml b/src-tauri/Cargo.toml
index aa76f4e..7b12904 100644
--- a/src-tauri/Cargo.toml
+++ b/src-tauri/Cargo.toml
@@ -64,6 +64,10 @@ md-5 = "0.10"
 notify = "8"
 walkdir = "2"
 
+# Pin erased-serde to 0.4.9: v0.4.10 has a build-script panic on Windows
+# (erased-serde is a transitive dep of serde-untagged → typeid)
+erased-serde = "=0.4.9"
+
 [dev-dependencies]
 tokio = { version = "1", features = ["macros", "rt", "rt-multi-thread"] }
 
diff --git a/src-tauri/tauri.conf.json b/src-tauri/tauri.conf.json
index e5b51c5..17c7827 100644
--- a/src-tauri/tauri.conf.json
+++ b/src-tauri/tauri.conf.json
@@ -1,7 +1,7 @@
 {
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "LLM_Wiki",
-  "version": "0.5.4.1",
+  "version": "0.5.4",
   "identifier": "com.llmwiki.app",
   "build": {
     "beforeDevCommand": "npm run dev",
diff --git a/src/App.tsx b/src/App.tsx
index 562cd9b..dca4648 100644
--- a/src/App.tsx
+++ b/src/App.tsx
@@ -251,6 +251,12 @@ function App() {
               typeof savedApi.allowUnauthenticated === "boolean"
                 ? savedApi.allowUnauthenticated
                 : false,
+            allowLanAccess:
+              typeof savedApi.allowLanAccess === "boolean"
+                ? savedApi.allowLanAccess
+                : false,
+            mcpEnabled:
+              typeof savedApi.mcpEnabled === "boolean" ? savedApi.mcpEnabled : false,
             token: savedApi.token ?? "",
           })
         }
-- 
2.54.0.windows.1

